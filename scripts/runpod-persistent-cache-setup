#!/usr/bin/env bash
set -euo pipefail

# Configure RunPod network-volume-backed caches for heavyweight downloads.
# Run this inside the pod before installing dependencies or downloading models.

CACHE_ROOT="${DEAD_KEYS_PERSISTENT_CACHE_ROOT:-}"

if [[ -z "$CACHE_ROOT" ]]; then
  for candidate in \
    /workspace/crockpot-experiments-cache \
    /runpod-volume/crockpot-experiments-cache \
    /mnt/runpod/crockpot-experiments-cache \
    /network-volume/crockpot-experiments-cache; do
    parent=$(dirname "$candidate")
    if [[ -d "$parent" ]] && mountpoint -q "$parent"; then
      CACHE_ROOT="$candidate"
      break
    fi
  done
fi

if [[ -z "$CACHE_ROOT" ]]; then
  echo "ERROR: could not auto-detect a network volume mount." >&2
  echo "Set DEAD_KEYS_PERSISTENT_CACHE_ROOT=/path/on/network-volume/crockpot-experiments-cache and rerun." >&2
  echo "Mounted filesystems:" >&2
  findmnt -t ext4,xfs,zfs,nfs,fuse.s3fs,fuseblk,overlay --output TARGET,SOURCE,FSTYPE,SIZE,AVAIL 2>/dev/null >&2 || true
  exit 1
fi

if [[ -d /workspace ]] && mountpoint -q /workspace; then
  CUDA_VENV="/workspace/venv"
else
  CUDA_VENV="$CACHE_ROOT/venvs/cuda"
fi

mkdir -p \
  "$CACHE_ROOT/huggingface" \
  "$CACHE_ROOT/torch" \
  "$CACHE_ROOT/pip" \
  "$CACHE_ROOT/uv" \
  "$CACHE_ROOT/triton" \
  "$CACHE_ROOT/venvs" \
  "$CACHE_ROOT/models"

PROFILE="$HOME/.crockpot-experiments-runpod-env"
cat > "$PROFILE" <<EOF
# Generated by crockpot-experiments/scripts/runpod-persistent-cache-setup
export DEAD_KEYS_PERSISTENT_CACHE_ROOT="$CACHE_ROOT"
export HF_HOME="$CACHE_ROOT/huggingface"
export HUGGINGFACE_HUB_CACHE="$CACHE_ROOT/huggingface/hub"
export TRANSFORMERS_CACHE="$CACHE_ROOT/huggingface/transformers"
export TORCH_HOME="$CACHE_ROOT/torch"
export PIP_CACHE_DIR="$CACHE_ROOT/pip"
export UV_CACHE_DIR="$CACHE_ROOT/uv"
export TRITON_CACHE_DIR="$CACHE_ROOT/triton"
export DEAD_KEYS_CUDA_VENV="$CUDA_VENV"
EOF

for rc in "$HOME/.bashrc" "$HOME/.profile"; do
  touch "$rc"
  if ! grep -Fq '. "$HOME/.crockpot-experiments-runpod-env"' "$rc"; then
    cat >> "$rc" <<'EOF'

# crockpot-experiments persistent RunPod caches
if [ -f "$HOME/.crockpot-experiments-runpod-env" ]; then
  . "$HOME/.crockpot-experiments-runpod-env"
fi
EOF
  fi
done

migrate_dir() {
  local src="$1"
  local dst="$2"
  if [[ -e "$src" && ! -L "$src" ]]; then
    mkdir -p "$(dirname "$dst")"
    if [[ ! -e "$dst" ]]; then
      mv "$src" "$dst"
    else
      rsync -a "$src"/ "$dst"/
      mv "$src" "$src.before-persistent-cache.$(date +%Y%m%d%H%M%S)"
    fi
    ln -s "$dst" "$src"
  elif [[ ! -e "$src" ]]; then
    mkdir -p "$(dirname "$src")"
    ln -s "$dst" "$src"
  fi
}

migrate_dir "$HOME/.cache/huggingface" "$CACHE_ROOT/huggingface"
migrate_dir "$HOME/.cache/torch" "$CACHE_ROOT/torch"
migrate_dir "$HOME/.cache/pip" "$CACHE_ROOT/pip"
migrate_dir "$HOME/.cache/uv" "$CACHE_ROOT/uv"
migrate_dir "$HOME/.triton" "$CACHE_ROOT/triton"

echo "Persistent cache root: $CACHE_ROOT"
echo "Environment file: $PROFILE"
echo "Verification:"
findmnt -T "$CACHE_ROOT" --output TARGET,SOURCE,FSTYPE,SIZE,AVAIL || true
for p in "$HOME/.cache/huggingface" "$HOME/.cache/torch" "$HOME/.cache/pip" "$HOME/.cache/uv" "$HOME/.triton"; do
  printf '%s -> ' "$p"
  readlink "$p" || echo "not a symlink"
done
