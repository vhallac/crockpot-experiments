#!/usr/bin/env bash
set -euo pipefail

# Dedicated CUDA environment for NVIDIA RunPod hosts. This keeps the local
# ROCm-pinned uv environment intact while installing CUDA PyTorch separately.
#
# Caching strategy:
# - DEAD_KEYS_CUDA_VENV points to a shared venv on the network volume
#   (set by scripts/runpod-persistent-cache-setup). All experiments reuse it.
# - First invocation in a pod installs deps from requirements-runpod-cuda.txt.
# - Subsequent invocations skip install because the venv already exists.
# - DEAD_KEYS_CUDA_SKIP_INSTALL=1 bypasses the install step entirely.
CALLER_DEAD_KEYS_CUDA_VENV="${DEAD_KEYS_CUDA_VENV:-}"
CALLER_DEAD_KEYS_CUDA_PYTHON="${DEAD_KEYS_CUDA_PYTHON:-}"
if [[ -f "$HOME/.crockpot-experiments-runpod-env" ]]; then
  # shellcheck disable=SC1091
  . "$HOME/.crockpot-experiments-runpod-env"
fi
if [[ -n "$CALLER_DEAD_KEYS_CUDA_VENV" ]]; then
  DEAD_KEYS_CUDA_VENV="$CALLER_DEAD_KEYS_CUDA_VENV"
fi
if [[ -n "$CALLER_DEAD_KEYS_CUDA_PYTHON" ]]; then
  DEAD_KEYS_CUDA_PYTHON="$CALLER_DEAD_KEYS_CUDA_PYTHON"
fi

VENV_DIR="${DEAD_KEYS_CUDA_VENV:-.venv-cuda}"
PYTHON_BIN="${DEAD_KEYS_CUDA_PYTHON:-python3}"

if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  uv venv --python "$PYTHON_BIN" "$VENV_DIR"
fi

if [[ "${DEAD_KEYS_CUDA_SKIP_INSTALL:-0}" != "1" ]]; then
  uv pip install --index-strategy unsafe-best-match --python "$VENV_DIR/bin/python" -r requirements-runpod-cuda.txt
fi
exec "$VENV_DIR/bin/python" "$@"
